# Copy to .env and adjust values: cp .env.example .env
# docker compose reads .env from the project root automatically.

# Required in production: signing key for JWTs (see server/auth.go).
JWT_SECRET=

# Listen address inside the container (default matches Dockerfile).
HTTP_ADDR=:6789

# SQLite file path inside the container (must stay under /data for the default volume).
DATABASE_PATH=/data/app.db

# Optional: Cloudflare Tunnel token for the cloudflared sidecar (docker compose service "tunnel").
# Leave unset if you expose the app port another way.
CLOUDFLARE_TOKEN=
